# ═════════════════════════════════════════════════════════════════════════════
# DARSI Backend Configuration
# ═════════════════════════════════════════════════════════════════════════════

# ── SurrealDB Configuration ───────────────────────────────────────────────────
SURREALDB_HOST=http://localhost:8000
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_NS=darsi
SURREALDB_DB=hospital

# ── API Configuration ─────────────────────────────────────────────────────────
API_HOST=localhost
API_PORT=8000
API_ENV=development

# ── Superadmin Default ────────────────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@darsi.local
SUPERADMIN_PASSWORD=Admin@12345

# ── JWT Configuration (optional) ───────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-this-in-production-12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
